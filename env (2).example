# Your app's Client secret (Dev Dashboard > your app > Settings)
SHOPIFY_API_SECRET=

# Your app's Client ID and Client secret (Dev Dashboard > your app > Settings)
# Note: SHOPIFY_API_SECRET and SHOPIFY_CLIENT_SECRET are the same value —
# it's used both to verify App Proxy signatures and to request access tokens.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Your store's .myshopify.com domain, no protocol
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Optional, defaults to a recent stable version
ADMIN_API_VERSION=2026-04

PORT=3000
